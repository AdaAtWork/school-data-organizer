# -------------------------------------------------------
# School Data Organizer — Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in your real values.
# Never commit .env to Git.
#
# Variable naming conventions:
#   DATABASE_URL   — server-side only. Never prefix with NEXT_PUBLIC_.
#   NEXT_PUBLIC_*  — safe to expose to the browser. No secrets here.

# -------------------------------------------------------
# DATABASE (server-side only — never use NEXT_PUBLIC_)
# -------------------------------------------------------
# Supabase PostgreSQL connection string.
# Source: Supabase Dashboard → Settings → Database → Connection string → URI
# Select "Session mode" (port 5432) — NOT Transaction mode (port 6543).
# Replace [YOUR-PASSWORD] with your actual Supabase database password.
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
